{
  "name": "sibsroutelookuptool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "sync:audio": "node scripts/sync-broadcast-audio.mjs",
    "sync:route-audio": "node scripts/sync-route-broadcast-audio.mjs",
    "sync:route-maps": "node scripts/sync-route-map-images.mjs",
    "sync:npc": "node scripts/sync-npc-audio.mjs",
    "gen:route-maps": "node scripts/build-route-maps-manifest.mjs",
    "sync:brand": "node scripts/sync-brand-assets.mjs",
    "gen:service-types": "node scripts/generate-route-service-types.mjs",
    "gen:stop-aliases": "node scripts/generate-stop-aliases.mjs",
    "import:routes": "node scripts/import-route-from-wiki.mjs --all && node scripts/compose-476-from-wiki.mjs && node scripts/build-route-unlocks.mjs && node scripts/build-sibs-routes-ts.mjs",
    "build:sibs-routes": "node scripts/compose-476-from-wiki.mjs && node scripts/build-route-unlocks.mjs && node scripts/build-sibs-routes-ts.mjs",
    "build": "node scripts/sync-broadcast-audio.mjs && node scripts/sync-route-broadcast-audio.mjs && tsc -b && vite build",
    "build:only": "vite build",
    "bot:daily": "node scripts/daily-challenge-bot.mjs",
    "bot:daily:api": "node scripts/daily-challenge-bot.mjs --api-only",
    "user-api": "node --env-file=.env scripts/user-api.mjs",
    "start:user-api": "node scripts/user-api.mjs",
    "publish:index": "node scripts/publish-standalone.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.26.4",
    "nodemailer": "^9.0.1",
    "opencc-js": "^1.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
